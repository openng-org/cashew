{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "rootDir": ".",
    "outDir": "../../../../dist/openng/cashew/schematics"
  },
  "include": ["ng-add/**/*.ts"],
  "exclude": ["**/*.spec.ts"]
}
